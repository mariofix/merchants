# Copy to .env and fill in values before running.

# Required
SECRET_KEY=change-me-to-something-random

# Optional: swap the provider (default: dummy)
# MERCHANTS_PROVIDER=stripe

# Stripe (if MERCHANTS_PROVIDER=stripe)
# STRIPE_API_KEY=sk_test_...

# Khipu (if MERCHANTS_PROVIDER=khipu)
# KHIPU_RECEIVER_ID=...
# KHIPU_SECRET=...

# Flow.cl (if MERCHANTS_PROVIDER=flow)
# FLOW_API_KEY=...
# FLOW_SECRET=...

# Webhook base URL — set to your public URL so providers can call back
# MERCHANTS_WEBHOOK_BASE_URL=https://yourapp.example.com
